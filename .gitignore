.cache/

# Claude Code cache — ignore everything under .claude/ EXCEPT the PROJECT
# memory scope, which lives in-repo under .claude/project/memory/ and MUST be
# tracked + pushed (the shared, cross-dev wiki memory). The bare-dir form would
# prune the whole tree so git never honors the re-include — use the /** form,
# then re-include each parent dir before the memory tree (order matters).
.claude/**
!.claude/project/
!.claude/project/memory/
!.claude/project/memory/**
# ...but re-ignore janitor detector outputs in the memory dir (machine-local,
# regenerated each heartbeat scan, may quote flagged content) — they must never
# reach the shared PROJECT scope, and they would otherwise dirty the tree and
# abort publish.py's clean-tree gate.
.claude/project/memory/*-proposed.md

# LLM Externalizer
llm_externalizer_output/

# TLDR
.tldr/

# SERENA MCP state (local project metadata, not published)
.serena/

# git-cliff scratch — ephemeral release notes between bump and push
.git-cliff-release-notes.md
